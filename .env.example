# Flask セッション用シークレットキー
APP_SECRET_KEY=your-random-secret-key-here

# アプリのURL（OAuthリダイレクトURI構築に使用）
# ローカル: http://127.0.0.1:5000
# Render:  https://your-app-name.onrender.com
APP_URL=http://127.0.0.1:5000

# Google OAuth クライアント（Web Application タイプ）
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Google OAuth トークン（Render永続化用）
# 初回認証後に表示されるJSON文字列を貼り付ける
# GOOGLE_TOKEN_JSON={"token": "...", "refresh_token": "...", ...}
